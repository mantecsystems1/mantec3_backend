@base_url = https://mantec3.portalmantec.com.br
@empresa_id = empresa-{{$timestamp}}
@usuario_id = usuario-{{$timestamp}}
@produto_id = produto-{{$timestamp}}
@auditoria_id = auditoria-{{$timestamp}}

### Criar
POST {{base_url}}/auditoria
Content-Type: application/json

{
  "empresaId": "{{empresa_id}}",
  "usuarioId": "{{usuario_id}}",
  "tipoEvento": "CREATE",
  "entidade": "produto",
  "entidadeId": "{{produto_id}}",
  "dados": {
    "descricao": "Evento gerado em {{$timestamp}}",
    "valorReferencia": {{$randomInt}}
  }
}

> {% client.global.set("auditoria_id", response.body._id); %}

### Buscar
GET {{base_url}}/auditoria/{{auditoria_id}}

### Listar
GET {{base_url}}/auditoria

### Atualizar
PATCH {{base_url}}/auditoria/{{auditoria_id}}
Content-Type: application/json

{
  "tipoEvento": "UPDATE",
  "dados": {
    "descricao": "Evento atualizado em {{$timestamp}}"
  }
}

### Deletar
DELETE {{base_url}}/auditoria/{{auditoria_id}}
